{
  "name": "easy-eval",
  "version": "0.1.0",
  "description": "A CLI toolkit for evaluating structured LLM outputs against golden datasets",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "ee": "src/cli.ts"
  },
  "scripts": {
    "ee": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test src/judges/judges.e2e.test.ts",
    "test:binary": "bun test src/binary.e2e.test.ts",
    "compile": "bun build src/cli.ts --compile --minify --sourcemap --outfile dist/ee",
    "compile:all": "bun run compile:darwin-arm64 && bun run compile:darwin-x64 && bun run compile:linux-x64 && bun run compile:linux-arm64",
    "compile:darwin-arm64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-darwin-arm64 --outfile dist/ee-darwin-arm64",
    "compile:darwin-x64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-darwin-x64 --outfile dist/ee-darwin-x64",
    "compile:linux-x64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile dist/ee-linux-x64",
    "compile:linux-arm64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-linux-arm64 --outfile dist/ee-linux-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "zod": "^3.24"
  },
  "peerDependencies": {
    "typescript": "^5",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}

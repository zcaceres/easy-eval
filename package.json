{
  "name": "easy-eval",
  "version": "0.1.0",
  "description": "A CLI toolkit for evaluating structured LLM outputs against golden datasets",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "ee": "src/cli.ts"
  },
  "scripts": {
    "ee": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test src/judges/judges.e2e.test.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "zod": "^3.24"
  },
  "peerDependencies": {
    "typescript": "^5",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}

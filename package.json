{
  "name": "vibecheck",
  "version": "0.1.0",
  "description": "A CLI toolkit for evaluating structured LLM outputs against golden datasets",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "vibecheck": "src/cli.ts"
  },
  "scripts": {
    "vibecheck": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test src/judges/judges.e2e.test.ts",
    "test:binary": "bun test src/binary.e2e.test.ts",
    "compile": "bun build src/cli.ts --compile --minify --sourcemap --outfile dist/vibecheck",
    "compile:all": "bun run compile:darwin-arm64 && bun run compile:darwin-x64 && bun run compile:linux-x64 && bun run compile:linux-arm64",
    "compile:darwin-arm64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-darwin-arm64 --outfile dist/vibecheck-darwin-arm64",
    "compile:darwin-x64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-darwin-x64 --outfile dist/vibecheck-darwin-x64",
    "compile:linux-x64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile dist/vibecheck-linux-x64",
    "compile:linux-arm64": "bun build src/cli.ts --compile --minify --sourcemap --target=bun-linux-arm64 --outfile dist/vibecheck-linux-arm64",
    "docs:api": "typedoc && cp docs/_api-index.md docs/api/index.md",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.10.0",
    "vitepress": "^1.6.0",
    "zod": "^3.24"
  },
  "peerDependencies": {
    "typescript": "^5",
    "zod": "^3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
